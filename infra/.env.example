# Copy to infra/.env and adjust as needed. docker-compose reads from .env automatically.

# Postgres
POSTGRES_USER=hexaloop
POSTGRES_PASSWORD=hexaloop
POSTGRES_DB=hexaloop
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Mailpit (SMTP server + web UI)
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# API
API_PORT=5080
HEXALOOP_JWT_SIGNINGKEY=dev-only-signing-key-please-replace-32-chars-min
HEXALOOP_SMTP_FROM=no-reply@hexaloop.dev
